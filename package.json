{
  "name": "ethos-forge",
  "version": "1.0.0",
  "private": true,
  "description": "Ethos Software proprietary starter kit — monorepo with reusable packages, generators, and a clonable starter template.",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "playground": "pnpm --filter @ethos/playground dev",
    "forge:gen:backend": "pnpm --filter @ethos/database db:generate && node tools/generators/forge-controller/index.js",
    "forge:gen:frontend": "pnpm --filter @ethos-app/web gen:api && node tools/generators/forge-page/index.js",
    "prepare": "husky",
    "storybook": "pnpm --filter @ethos/ui storybook"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "@ethos/config": "workspace:*",
    "@types/node": "^20.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^14.0.0",
    "eslint-import-resolver-typescript": "^3.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tsx": "^4.19.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
