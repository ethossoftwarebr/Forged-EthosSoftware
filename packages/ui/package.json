{
  "name": "@ethos/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Biblioteca proprietária de componentes UI da Ethos Forge — primitivos shadcn customizados, compostos e layouts, com preset Tailwind exportável.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
