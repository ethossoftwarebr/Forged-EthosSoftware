    "@storybook/react": "^8.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.4.9",
