// Ethos Forge — schema central (single source of truth).
//
// Decisões travadas em .claude/spec/active/2026-05-08-ethos-auth-multitenant/spec.md:
//   D9   schema central, apps consomem via prisma.schema em package.json
//   D12  OAuth-ready (User.password nullable, OAuthAccount table)
//   D14  Auth Roadmap Modular (MFA + magic link + lockout schema-ready)
//   D15  White-label (Tenant.settings + brandColor + logoUrl + appName + locale)
//
// Estratégia multi-tenant: User pode pertencer a N tenants via TenantMember (M:N).
// `tenantId` em RefreshToken/Session/AuditLog identifica o contexto da sessão,
// não vínculo do User.

generator client {
  provider = "prisma-client-js"
}

generator nestjsDto {
  provider                        = "prisma-generator-nestjs-dto"
  output                          = "../../../templates/starter/apps/api/src/generated/dto"
  outputToNestJsResourceStructure = "false"
  flatResourceStructure           = "false"
  exportRelationModifierClasses   = "true"
  reExport                        = "false"
  createDtoPrefix                 = "Create"
  updateDtoPrefix                 = "Update"
  dtoSuffix                       = "Dto"
  entityPrefix                    = ""
  entitySuffix                    = ""
  classValidation                 = "false"
  fileNamingStyle                 = "kebab"
  noDependencies                  = "false"
  outputType                      = "class"
  definiteAssignmentAssertion     = "true"
  requiredResponseApiProperty     = "true"
  prettier                        = "true"
}

generator nestjsCrud {
  provider = "prisma-crud-generator"
  output   = "../../../templates/starter/apps/api/src/generated/crud"
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL é carregada pela raiz do monorepo (.env) via dotenv-cli.
  // Scripts em packages/database/package.json fazem `dotenv -e ../../.env -- prisma <cmd>`.
  // NÃO criar `.env` aqui — drift garantido. Single source: <root>/.env (gitignored).
  // Ver Wave 5 do spec 2026-05-11-ethos-gen-hardening.
  url      = env("DATABASE_URL")
}

// ============================================================================
// Tenant — conta multi-tenant + white-label config (D15)
// ============================================================================

model Tenant {
  id         String  @id @default(cuid())
  slug       String  @unique // usado em subdomain routing (acme.app.com)
  name       String
  // White-label (D15) — schema-ready pra spec #18
  settings   Json?
  brandColor String?
  logoUrl    String?
  appName    String?
  locale     String  @default("pt-BR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           TenantMember[]
  refreshTokens     RefreshToken[]
  sessions          Session[]
  auditLogs         AuditLog[]
  magicLinks        MagicLinkToken[]
  chatConversations ChatConversation[]
  documents         Document[]
}

// ============================================================================
// User — identidade global; vínculo com tenant via TenantMember (M:N)
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String? // nullable — usuário OAuth-only nunca teve senha (D12)
  name          String?
  image         String? // avatar do OAuth provider (D12)
  emailVerified DateTime? // Google OAuth já entrega verificado (D12)

  // MFA (D14.4) — schema-ready pra #8.7
  // @deprecated V1.1 — usar MfaSecret (D8.7.9); mantido pra retro-compat até migration data
  totpSecret String?
  mfaEnabled Boolean @default(false)

  // Lockout / rate limiting (D14.6 — IMPLEMENTADO em #8)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           TenantMember[]
  oauthAccounts     OAuthAccount[]
  refreshTokens     RefreshToken[]
  sessions          Session[]
  auditLogs         AuditLog[]
  mfaBackupCodes    MfaBackupCode[]
  mfaSecrets        MfaSecret[]
  chatConversations ChatConversation[]
}

// ============================================================================
// Roles — princípio do menor privilégio (CLAUDE.md)
// ============================================================================

enum Role {
  owner
  admin
  manager
  member
  viewer
}

model TenantMember {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      Role     @default(member)
  invitedBy String? // userId do quem convidou (audit trail)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

// ============================================================================
// OAuth Account (D12) — schema-ready pra spec #8.5
// Provider e providerAccountId vêm do Google/Microsoft.
// ============================================================================

model OAuthAccount {
  id                String    @id @default(cuid())
  userId            String
  provider          String // "google" | "microsoft" — string pra extensibilidade
  providerAccountId String
  accessToken       String?   @db.Text
  refreshToken      String?   @db.Text
  expiresAt         DateTime?
  idToken           String?   @db.Text
  scope             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============================================================================
// RefreshToken (D5 + D13.5) — rotation mandatory + hash em DB
// `tokenHash` é argon2id(token); o token plaintext só vive no cookie do client.
// `family` agrupa tokens irmãos pra detectar reuse (D5 — token reuse = revoga family inteira).
// ============================================================================

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique // argon2id(token plaintext) — D13.5
  userId    String
  tenantId  String // sessão é por-tenant (multi-tenant context)
  family    String // grupo de tokens irmãos pra detecção de reuse
  expiresAt DateTime
  revokedAt DateTime?
  rotatedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, tenantId])
  @@index([family])
  @@index([expiresAt])
}

// ============================================================================
// Session — telemetria de sessões ativas (analytics + ops)
// Diferente de RefreshToken: Session é metadata; RefreshToken é credencial.
// ============================================================================

model Session {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  userAgent  String?
  ip         String?
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, tenantId])
  @@index([expiresAt])
}

// ============================================================================
// AuditLog (D7 — síncrono no #8; refactor pra BullMQ em #15)
// ============================================================================

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String? // null pra ações pré-auth ou sistema
  action       String // "user.create" | "auth.login" | "tenant.update" etc.
  resourceType String? // "User" | "Tenant" | "TenantMember"
  resourceId   String?
  meta         Json? // payload adicional (mascarado de PII pelo interceptor)
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([action])
}

// ============================================================================
// MFA Backup Codes (D14.4) — schema-ready pra #8.7
// codeHash é argon2id; usedAt single-use.
// ============================================================================

model MfaBackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================================
// MfaSecret (D8.7.9) — secret TOTP encriptado AES-256-GCM (D8.7.4).
// Substitui User.totpSecret (deprecated V1.1). Pendente de confirmação: row
// criada no /setup com verifiedAt=null; marca verifiedAt=now() no /setup/confirm.
// ============================================================================

model MfaSecret {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  secretEnc  String // AES-256-GCM ciphertext do segredo base32 (D8.7.4)
  verifiedAt DateTime? // null = setup pendente; set = confirmado e ativo
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
}

// ============================================================================
// MagicLinkToken (D14.4) — schema-ready pra #8.6
// `email` não é FK — magic link pode disparar registro se User não existir.
// `tenantId` inferido do subdomain de origem (#8.6 trava decisão).
// ============================================================================

model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tenantId  String
  // SHA-256 hex do token plaintext (32B base64url, 256-bit entropy).
  // Argon2id é não-determinístico (salt) — impossibilita lookup direto por @unique.
  // SHA-256 é seguro pra tokens de alta entropia + TTL curto + single-use (W1.B do #8.6).
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email, tenantId])
  @@index([expiresAt])
}

// ============================================================================
// Product (exemplo do prompt #9 — valida generators end-to-end via /// @forge.generate)
// ============================================================================

/// @forge.generate(controller, page)
model Product {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  sku         String
  price       Decimal  @db.Decimal(12, 2)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, sku])
  @@index([tenantId])
}

// ============================================================================
// Chat — @ethos/ai-chat (prompt #13). Sem /// @forge.generate (D#13.6 — interno do package).
// ============================================================================

enum ChatRole {
  user
  assistant
  system
  tool
}

model ChatConversation {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           ChatRole
  content        String   @db.Text
  toolCalls      Json? // array de tool_use blocks quando role=assistant
  toolCallId     String? // referência ao tool_use_id quando role=tool
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ============================================================================
// AI RAG — @ethos/ai-rag (prompt #14).
// Decisões travadas em .claude/spec/active/2026-05-13-ethos-ai-rag/spec.md:
//   D#14.2   vector(1024) fixo V1 — Prisma Unsupported (sem tipo nativo)
//   D#14.7   operator <#> (inner product) — HNSW usa vector_ip_ops
//   D#14.12  1 tabela DocumentChunk + coluna embedder (modelo usado)
//   D#14.13  imagem docker pgvector/pgvector:pg16
//   D#14.14  migration SQL manual + -- prisma:no-drop no HNSW (Prisma #28414)
// ============================================================================

enum DocumentSourceType {
  file
  text
  url
}

enum DocumentStatus {
  pending
  processing
  ready
  failed
}

enum RagIngestJobStatus {
  waiting
  active
  completed
  failed
}

model Document {
  id           String             @id @default(cuid())
  tenantId     String
  // userId: referência informativa (ownership). Sem FK formal — multi-tenant filtra via tenantId.
  userId       String
  sourceType   DocumentSourceType
  sourceUrl    String?
  title        String
  status       DocumentStatus     @default(pending)
  metadata     Json?
  embedderUsed String // modelo usado, ex.: "voyage-3-large" (D#14.12)
  chunksCount  Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks     DocumentChunk[]
  ingestJobs RagIngestJob[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model DocumentChunk {
  id         String                       @id @default(cuid())
  documentId String
  // tenantId denormalizado pra filtro rápido em retrieval —
  // D#14.7 exige tenantId ANTES do similarity search.
  tenantId   String
  index      Int // ordem do chunk dentro do Document
  content    String                       @db.Text
  embedding  Unsupported("vector(1024)") // D#14.2 — vector(1024) fixo V1
  embedder   String // D#14.12 — modelo que gerou o embedding
  tokens     Int
  metadata   Json?
  createdAt  DateTime                     @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // HNSW index em `embedding` é custom SQL (vector_ip_ops) — vive na migration manual (D#14.14).
  @@index([tenantId, documentId])
  @@index([documentId, index])
}

model RagIngestJob {
  id         String             @id @default(cuid())
  documentId String
  tenantId   String
  status     RagIngestJobStatus @default(waiting)
  error      String?
  retries    Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([documentId])
}
