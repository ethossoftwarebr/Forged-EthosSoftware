{
  "name": "@ethos/database",
  "version": "0.1.0",
  "private": true,
  "description": "Schema central Prisma + client wrapper + tipos derivados. Source of truth do schema multi-tenant (Tenant, User, Session, AuditLog, OAuthAccount, MagicLinkToken, MfaBackupCode, RefreshToken). Implementado no prompt #8.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./extension/tenant": "./src/extension/tenant.ts"
  },
  "scripts": {
    "lint": "echo 'placeholder'",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=./prisma/schema.prisma",
    "db:seed": "tsx ./prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@ethos/auth": "workspace:*",
    "@ethos/config": "workspace:*",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "tsx ./prisma/seed.ts"
  }
}
