import { PRISMA_CLIENT_TOKEN } from '@ethos/api-base';
import { type Prisma, type PrismaClient } from '@ethos/database';
import { Inject, Injectable } from '@nestjs/common';

/**
 * {{plural className}}Repository — gerado pelo Forge (prompt #9).
 *
 * Wrapper sobre `prisma.{{varName}}` com filtro automático por `tenantId`.
 * Regenerado a cada `forge:gen:backend` — NÃO customizar aqui.
 * Para customizar queries, faça override no service ({{resourcePath}}.service.ts).
 *
 * Pattern de safety multi-tenant (D7): `updateMany`/`deleteMany` com
 * `where: { id, tenantId }` em vez de `update`/`delete` por id puro.
 * Isso garante 0 linhas afetadas em cross-tenant attempts (sem 500/leak).
 */
@Injectable()
export class {{plural className}}Repository {
  constructor(@Inject(PRISMA_CLIENT_TOKEN) private readonly prisma: PrismaClient) {}

  findMany(
    tenantId: string,
    args: Omit<Prisma.{{className}}FindManyArgs, 'where'> & { where?: Prisma.{{className}}WhereInput } = {},
  ) {
    return this.prisma.{{varName}}.findMany({
      ...args,
      where: { ...args.where, tenantId },
    });
  }

  count(tenantId: string, where: Prisma.{{className}}WhereInput = {}) {
    return this.prisma.{{varName}}.count({ where: { ...where, tenantId } });
  }

  findFirst(tenantId: string, id: string) {
    return this.prisma.{{varName}}.findFirst({ where: { id, tenantId } });
  }

  create(tenantId: string, data: Omit<Prisma.{{className}}CreateInput, 'tenantId'>) {
    return this.prisma.{{varName}}.create({
      data: { ...(data as Prisma.{{className}}CreateInput), tenantId },
    });
  }

  async update(tenantId: string, id: string, data: Prisma.{{className}}UpdateInput) {
    const result = await this.prisma.{{varName}}.updateMany({
      where: { id, tenantId },
      data,
    });
    if (result.count === 0) return null;
    return this.prisma.{{varName}}.findUnique({ where: { id } });
  }

  async delete(tenantId: string, id: string): Promise<boolean> {
    const result = await this.prisma.{{varName}}.deleteMany({ where: { id, tenantId } });
    return result.count > 0;
  }
}
