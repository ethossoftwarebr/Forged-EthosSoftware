'use client';

import { FormBuilder } from '@ethos/ui';
import { useMutation, useQueryClient } from '@tanstack/react-query';
import { useRouter } from 'next/navigation';
import { toast } from 'sonner';

import {
  {{createMutation}},
  {{listQueryKey}},
} from '@/generated/api/@tanstack/react-query.gen';
import type { {{Model}}Entity } from '@/generated/api/types.gen';
import { {{createBodySchema}} } from '@/generated/api/zod.gen';

import { {{model}}FormFields } from '../_components/FormFields';

/**
 * Página de criação de {{Model}}.
 *
 * Schema Zod e tipo do body vêm direto do OpenAPI (zod.gen + types.gen).
 * Ao sucesso, invalida a query da lista via prefix do queryKey gerado pelo
 * hey-api (matching por `_id` — invalida todas as paginações/buscas) e
 * redireciona pra página de detalhes do recurso.
 *
 * Customize livremente — pra travar este arquivo contra regen, remova o
 * header AUTOGEN da primeira linha.
 */
export default function {{Model}}CreatePage() {
  const router = useRouter();
  const qc = useQueryClient();

  const create = useMutation({{createMutation}}());

  // Extrai o `_id` do queryKey gerado pelo hey-api — usado como prefixo
  // pra invalidar todas as queries de listagem (qualquer combinação de paginação/busca).
  const listKeyId = {{listQueryKey}}({
    query: { take: 0, skip: 0, search: '' },
  })[0]._id;

  return (
    <div className="space-y-6 p-6 max-w-2xl">
      <header>
        <h1 className="text-2xl font-semibold">Novo {{Model}}</h1>
        <p className="text-sm text-muted-foreground">
          Preencha os campos abaixo para criar um {{Model}}.
        </p>
      </header>

      <FormBuilder
        schema={ {{createBodySchema}} }
        fields={ {{model~}} FormFields}
        onSubmit={async (values) => {
          try {
            const created = (await create.mutateAsync({
              body: values,
            })) as {{Model}}Entity | undefined;
            await qc.invalidateQueries({ queryKey: [{ _id: listKeyId }] });
            toast.success('{{Model}} criado com sucesso.');
            router.push(created?.id ? `/{{slug}}/${created.id}` : '/{{slug}}');
          } catch (err) {
            toast.error(err instanceof Error ? err.message : 'Erro ao criar {{Model}}.');
          }
        }}
        onCancel={() => router.push('/{{slug}}')}
        submitLabel="Criar"
      />
    </div>
  );
}
