NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://ethos:ethos_dev_password@localhost:5432/ethos_dev
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# =============================================================================
# JWT Keyset (D13 — hardening)
# =============================================================================
# Algoritmo único: EdDSA / Ed25519. JWT_SECRET (HS*) foi REMOVIDO — D13.1 proíbe.
#
# Gere as chaves com:
#   pnpm --filter @ethos/auth generate-keys
#
# Esse script imprime as 2 chaves PEM já com `\n` escapado pra colar aqui direto.
# Em produção, prefira secret manager (Railway/Vercel envs, AWS Secrets, etc.).
#
# Rotação (D13.4): pra rotacionar sem invalidar tokens existentes, popule
# JWT_KID_PREVIOUS + JWT_PUBLIC_KEY_PREVIOUS com a chave antiga durante a
# janela de transição (~30d = TTL do refresh token).

JWT_KID_CURRENT=2026-05-10
JWT_PRIVATE_KEY_CURRENT="-----BEGIN PRIVATE KEY-----\n<placeholder>\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY_CURRENT="-----BEGIN PUBLIC KEY-----\n<placeholder>\n-----END PUBLIC KEY-----\n"
# JWT_KID_PREVIOUS=2026-04-01
# JWT_PUBLIC_KEY_PREVIOUS="-----BEGIN PUBLIC KEY-----\n<old>\n-----END PUBLIC KEY-----\n"

# Cookie domain (opcional). Vazio = host-only. Em prod, ex: ".acme.app".
# COOKIE_DOMAIN=

# =============================================================================
# Web base URL (D8.5.5)
# =============================================================================
# URL pública do app Next.js — usado pra montar redirects de erro/sucesso do
# OAuth callback. Em prod, aponte pro host real (ex: https://app.acme.com).
WEB_BASE_URL=http://localhost:3000

# =============================================================================
# OAuth providers (D8.5) — opcional, descomente conforme uso.
# =============================================================================
# Cada provider precisa dos 3 campos (CLIENT_ID + CLIENT_SECRET + REDIRECT_URI)
# senão é "skipped" silenciosamente no boot (log: `[OAuth] {name}: skipped`).
#
# Crie credenciais em:
#   Google     https://console.cloud.google.com/apis/credentials
#   Microsoft  https://entra.microsoft.com  (App registrations)
#
# REDIRECT_URI deve apontar pro **callback do backend**, ex:
#   http://localhost:3001/auth/google/callback
#   https://api.acme.com/auth/microsoft/callback

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_REDIRECT_URI=http://localhost:3001/auth/microsoft/callback

# Chave AES-256-GCM (64 chars hex = 32 bytes) pra cifrar OAuth refresh tokens
# at-rest. OBRIGATÓRIO se qualquer provider OAuth estiver configurado acima.
# Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OAUTH_TOKEN_ENCRYPTION_KEY=
