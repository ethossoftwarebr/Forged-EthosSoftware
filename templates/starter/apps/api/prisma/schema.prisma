// Placeholder schema for templates/starter/apps/api/.
//
// Real schema lives in @ethos/database (added in prompt #8) — this file
// exists so `prisma generate` has a buildable target during the Dockerfile
// builder stage and `pnpm db:generate` doesn't error out.
//
// The single `PlaceholderHealth` model below is intentionally throwaway:
// Prisma 5 refuses to generate when 0 models are declared, so we declare
// a no-op model that won't be referenced anywhere in the app code. When
// prompt #8 lands and @ethos/database becomes the source of truth, this
// schema will either be deleted or re-pointed at the package via the
// `prisma.schema` field of package.json (decision deferred to #8).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Placeholder model — DO NOT USE in app code. Replaced in prompt #8.
model PlaceholderHealth {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}
