{
  "name": "@ethos-app/api",
  "version": "0.0.1",
  "private": true,
  "description": "Ethos starter API — NestJS 10",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "db:generate": "pnpm --filter @ethos/database db:generate",
    "db:migrate": "pnpm --filter @ethos/database db:migrate",
    "db:studio": "pnpm --filter @ethos/database db:studio",
    "db:seed": "pnpm --filter @ethos/database db:seed"
  },
  "prisma": {
    "schema": "../../../packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@ethos/api-base": "workspace:^",
    "@ethos/auth": "workspace:^",
    "@ethos/database": "workspace:^",
    "@ethos/email": "workspace:^",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "nestjs-pino": "^4.4.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.0.4"
  },
  "devDependencies": {
    "@ethos/config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.22",
    "@types/compression": "^1.8.1",
    "@types/cookie": "^1.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "jose": "^5.10.0",
    "@types/node": "^20.19.40",
    "@types/supertest": "^7.2.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "otplib": "^12.0.1",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
