# =============================================================================
# Ethos Starter — variáveis de ambiente
# =============================================================================
# Copie esse arquivo: cp templates/starter/.env.example templates/starter/.env
# Preencha valores REAIS. Nunca commitar `.env`.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database (Postgres 16) — usado por @ethos/database e pelo api
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://ethos:ethos_dev_password@localhost:5432/ethos_dev

# -----------------------------------------------------------------------------
# Redis (BullMQ + cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# CORS / Cookies
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
# COOKIE_DOMAIN deixar vazio em dev (host-only); em prod, ex: ".acme.app"
COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# JWT Keyset (D13 — EdDSA / Ed25519 obrigatório, HS* PROIBIDO)
# -----------------------------------------------------------------------------
# Gere com: pnpm --filter @ethos/auth generate-keys
# O script imprime as 2 chaves PEM já com `\n` escapado pra colar aqui direto.
# Em produção, prefira secret manager (Railway envs, AWS Secrets, etc.).
#
# Rotação: pra rotacionar sem invalidar tokens existentes, popule
# JWT_KID_PREVIOUS + JWT_PUBLIC_KEY_PREVIOUS com a chave antiga durante a
# janela de transição (~30d = TTL do refresh token).

JWT_KID_CURRENT=2026-05-10
JWT_PRIVATE_KEY_CURRENT="-----BEGIN PRIVATE KEY-----\n<placeholder>\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY_CURRENT="-----BEGIN PUBLIC KEY-----\n<placeholder>\n-----END PUBLIC KEY-----\n"
# JWT_KID_PREVIOUS=2026-04-01
# JWT_PUBLIC_KEY_PREVIOUS="-----BEGIN PUBLIC KEY-----\n<old>\n-----END PUBLIC KEY-----\n"

# -----------------------------------------------------------------------------
# Seed (obrigatório antes de rodar `pnpm db:seed`)
# -----------------------------------------------------------------------------
# Senha do admin demo criado pelo seed. Sem default público por segurança.
# Mínimo 12 chars. Em prod, use senha forte gerada e descarte após o primeiro login.
SEED_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_TENANT=acme

# -----------------------------------------------------------------------------
# Pacotes plugáveis — preencha apenas os que vai usar
# -----------------------------------------------------------------------------
# IA (@ethos/ai-chat, @ethos/ai-rag, @ethos/ocr)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Google (@ethos/google — Calendar, Drive, Sheets)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# WhatsApp (@ethos/whatsapp — Z-API + WABA)
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# WABA_PHONE_NUMBER_ID=
# WABA_ACCESS_TOKEN=

# Payments (@ethos/payments)
# MERCADO_PAGO_ACCESS_TOKEN=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAGSEGURO_TOKEN=

# ERP (@ethos/erp-bridge)
# BLING_API_KEY=
# TINY_TOKEN=
# OMIE_APP_KEY=
# OMIE_APP_SECRET=

# n8n (@ethos/n8n)
# N8N_BASE_URL=
# N8N_API_KEY=
