# ============================================================================
# Ethos Forge — variáveis de ambiente do monorepo (dev local)
# ----------------------------------------------------------------------------
# Copie pra .env (ignorado pelo git) e ajuste conforme necessário.
# Cada app/package pode ter seu próprio .env adicional pro escopo dele.
# ============================================================================

# --- Postgres (consumido pelo docker-compose.yml) ---
POSTGRES_USER=ethos
POSTGRES_PASSWORD=ethos_dev_password
POSTGRES_DB=ethos_dev
POSTGRES_PORT=5432

# DATABASE_URL é o que o Prisma usa. Aponta pro Postgres do docker-compose.
DATABASE_URL=postgresql://ethos:ethos_dev_password@localhost:5432/ethos_dev?schema=public

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
